{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [{ "source": "/", "destination": "/web/index.html" }],
  "headers": [
    {
      "source": "/(.*)\\.mjs",
      "headers": [{ "key": "Content-Type", "value": "application/javascript; charset=utf-8" }]
    }
  ]
}
