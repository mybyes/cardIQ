# CardIQ environment — copy to .env for local, or set in Railway's Variables tab.
# Nothing here is required for the Tier-0 (curated-data) launch; all are for later tiers.

# Port — Railway injects this automatically; only set it for local dev.
# PORT=4322

# --- Later: live data feeds (see GO-LIVE-CHECKLIST.md) ---
# OTA / coupon offers feed (Cuelinks / CouponAPI / Admitad)
# OTA_FEED_URL=

# AI concierge (top tier) — server-side Claude, metered
# ANTHROPIC_API_KEY=

# CORS allow-list for the API (unset = allow all; set for production hardening)
# ALLOWED_ORIGINS=https://cardiq.app

# NOTE: Google sign-in uses a CLIENT-SIDE Client ID set in web/login.html
# (var GOOGLE_CLIENT_ID), not an env var. See GOOGLE-SIGNIN-SETUP.md.
